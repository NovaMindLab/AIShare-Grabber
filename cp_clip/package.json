{
  "name": "image-clip-classifier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:dev": "electron .",
    "dev": "concurrently -k \"npm run vite:dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "electron-builder"
  },
  "dependencies": {
    "onnxruntime-node": "^1.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.4",
    "sqlite3": "^6.0.1",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^8.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shareclip.album.sync",
    "productName": "ShareCLIP",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "tokenizer.cjs",
      "merges.txt",
      "text_embeddings.json",
      "mobileclip_image_encoder.onnx",
      "mobileclip_text_encoder_quant.onnx",
      "package.json",
      "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**/*",
      "!node_modules/onnxruntime-node/bin/napi-v6/linux/**/*",
      "!node_modules/onnxruntime-node/bin/napi-v6/win32/arm64/**/*"
    ],
    "asar": false,
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
